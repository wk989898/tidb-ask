FEISHU_EVENT_TRANSPORT=ws
CODEX_TIMEOUT=90m
CODEX_LOG_OUTPUT=false
FEISHU_DEBUG=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REPLY_FORMAT=markdown
FEISHU_PROCESSING_INDICATOR=reaction
FEISHU_PROCESSING_REACTION_EMOJI_TYPE=THINKING

FEISHU_GROUP_MODE=mention
FEISHU_TIDB_ONLY=true

# Ensure go is in PATH (this host installs go via g at /root/.g/versions/1.25.6/bin)
PATH=/root/.g/versions/1.25.6/bin:$PATH
